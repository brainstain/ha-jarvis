# ============================================================
# Environment Variables Template
# Copy to .env and fill in all values before deploying
# ============================================================

# ── Network ────────────────────────────────────────────────
DOMAIN=example.com
GATEWAY_IP=192.168.1.10
AGENT_IP=192.168.1.11
INFERENCE_IP=192.168.1.12
NAS_IP=192.168.1.13
TIMEZONE=America/New_York

# ── Reverse Proxy (external Traefik host) ─────────────────
TRAEFIK_IP=192.168.1.1

# ── Gateway: Authentik (Phase 2) ───────────────────────────
AUTHENTIK_SECRET_KEY=
AUTHENTIK_DB_PASSWORD=

# ── Gateway: Pi-hole ───────────────────────────────────────
PIHOLE_PASSWORD=

# ── Gateway: NUT (UPS Management) ──────────────────────────
NUT_USER=admin
NUT_PASSWORD=

# ── Agent: Grafana ─────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# ── Agent: Paperless-NGX (Phase 3) ─────────────────────────
PAPERLESS_DB_PASSWORD=
PAPERLESS_SECRET_KEY=
PAPERLESS_API_TOKEN=
