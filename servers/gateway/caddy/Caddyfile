# ============================================================
# Caddyfile — Gateway Reverse Proxy
# All external traffic routes through here
# ============================================================

{
	# Global options
	email admin@{$DOMAIN}
	acme_dns cloudflare {env.CF_API_TOKEN}
}

# ── Home Assistant ───────────────────────────────────────────
ha.{$DOMAIN} {
	reverse_proxy http://localhost:8123
}

# ── Open WebUI (Chat) ───────────────────────────────────────
chat.{$DOMAIN} {
	reverse_proxy http://{$AGENT_IP}:3000
}

# ── Grafana ──────────────────────────────────────────────────
grafana.{$DOMAIN} {
	reverse_proxy http://{$AGENT_IP}:3100
}

# ── Uptime Kuma ──────────────────────────────────────────────
status.{$DOMAIN} {
	reverse_proxy http://localhost:3001
}

# ── SearXNG ──────────────────────────────────────────────────
search.{$DOMAIN} {
	reverse_proxy http://localhost:8888
}

# ── Authentik ────────────────────────────────────────────────
auth.{$DOMAIN} {
	reverse_proxy http://localhost:9000
}

# ── Paperless-NGX ────────────────────────────────────────────
docs.{$DOMAIN} {
	reverse_proxy http://{$NAS_IP}:8000
}

# ── Perplexica ───────────────────────────────────────────────
research.{$DOMAIN} {
	reverse_proxy http://{$AGENT_IP}:3999
}

# ── Agent API (internal only — restrict to local network) ───
agent.{$DOMAIN} {
	@blocked not remote_ip 192.168.1.0/24
	respond @blocked "Forbidden" 403
	reverse_proxy http://{$AGENT_IP}:8100
}

# ── Pi-hole Admin ────────────────────────────────────────────
pihole.{$DOMAIN} {
	reverse_proxy http://localhost:8053
}
